# Reference only — secrets live in Doppler (see docs/doppler.md).
# Do not copy to .env / .env.local; use `doppler setup` then `pnpm dev`.

# --- Shared (monorepo) ---
# Runtime: pooling URL (Supabase Supavisor :6543). Migrations: set DIRECT_URL (:5432) in Doppler
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cocreate?schema=public"
# DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# --- @cocreate/api ---
PORT=3001
API_VERSION=1
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3002,http://localhost:3003
CLIENT_PORTAL_URL=http://localhost:3003
ADMIN_API_KEY=dev-admin-key-change-me
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# --- @cocreate/admin-center ---
# API_URL=http://localhost:3001
# ADMIN_API_KEY=dev-admin-key-change-me

# --- @cocreate/api — billing (see apps/api/.env.example) ---
# BILLING_FROM_EMAIL=billingupdates@mail.cocreatecaribbean.com
# FYGARO_SECRET=
# FYGARO_PAYMENT_BUTTON_URL=

# --- @cocreate/web — Sanity Presentation preview (see docs/sanity-preview.md) ---
# NEXT_PUBLIC_SANITY_PROJECT_ID=5ix7h4ht
# NEXT_PUBLIC_SANITY_DATASET=dev
# SANITY_STUDIO_DATASET=dev
# SANITY_API_TOKEN=
# SANITY_STUDIO_PREVIEW_URL=http://localhost:3000
# NEXT_PUBLIC_SANITY_STUDIO_URL=http://localhost:3333
# SANITY_REVALIDATE_SECRET=

# --- @cocreate/web ---
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_API_VERSION=1

# Vercel AI SDK — contact chat (/api/chat)
OPENAI_API_KEY=
# Or Vercel AI Gateway (non-Vercel deploys): https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=
OPENAI_MODEL=gpt-4o-mini
