# --- Shared (monorepo) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cocreate?schema=public"

# --- @cocreate/api (apps/api/.env) ---
PORT=3001
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# --- @cocreate/web (apps/web/.env.local) ---
# NestJS (future client calls)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Vercel AI SDK — contact chat (/api/chat)
OPENAI_API_KEY=
# Or Vercel AI Gateway (non-Vercel deploys): https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=
OPENAI_MODEL=gpt-4o-mini
