{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@cocreate/api-contracts/v1/*": ["../api-contracts/dist/v1/*"],
      "@cocreate/social-listening/core": ["../social-listening/dist/core/index.d.ts"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*"]
}
