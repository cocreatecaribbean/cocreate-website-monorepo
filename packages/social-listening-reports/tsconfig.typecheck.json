{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@cocreate/api-contracts/v1/*": ["../api-contracts/src/v1/*"]
    },
    "types": ["node"]
  },
  "include": ["src/**/*"]
}
