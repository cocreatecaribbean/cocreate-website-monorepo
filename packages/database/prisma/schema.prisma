// Prisma schema — PostgreSQL (local Docker, Supabase prod)
// https://www.prisma.io/docs

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

// ─── Multi-tenant client portal ─────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  /// Agency freelancer — project-scoped access via AgencyProjectMember
  COLLABORATOR
  CLIENT
}

enum UserStatus {
  /// Account provisioned by agency; magic link / invite pending
  INVITED
  /// Client authenticated and session is live
  ACTIVE
  /// Access revoked by agency
  SUSPENDED
}

/// Role within a client organization (CLIENT users only)
enum ClientOrgRole {
  ADMIN
  CONTRIBUTOR
  VIEWER
  SOCIAL_ANALYST
}

enum ClientTeamInviteRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

/// Client company (tenant boundary for portal + premium features)
model Organization {
  id                          String   @id @default(cuid())
  name                        String
  /// Unique subdomain / routing key (e.g. acme-corp)
  slug                        String   @unique
  /// Public URL to client logo (CDN, Supabase Storage, etc.)
  logoUrl                     String?
  isSocialListeningSubscriber Boolean  @default(false)
  /// Brand24 / BrandMentions project id — set in Admin Center when subscription is live
  brand24ProjectId            String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
  users                       User[]   @relation("UserLegacyOrganization")
  memberships                 ClientOrganizationMembership[]
  lastActiveUsers             User[]   @relation("UserLastActiveOrganization")
  socialListeningSnapshots    SocialListeningSnapshot[]
  clientProjects              ClientProject[]
  portalNotifications         PortalNotification[]
  teamInviteRequests          ClientTeamInviteRequest[]
  brandAssets                 OrganizationBrandAsset[]
  socialListeningSubscription SocialListeningSubscription?
  socialListeningSetups       SocialListeningSetup[]
  orgInboxConversations      OrgInboxConversation[]
  orgInboxAttachments        OrgInboxAttachment[]
  messageEmailDigests        MessageEmailDigest[]

  deletedAt DateTime?

  @@index([slug])
  @@index([deletedAt])
}

/// Admin-only brand guidelines per client (style guides, logos, PDFs)
model OrganizationBrandAsset {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  storagePath      String
  fileName         String
  mimeType         String
  sizeBytes        Int
  uploadedByUserId String
  uploadedBy       User         @relation("BrandAssetUploadedBy", fields: [uploadedByUserId], references: [id])
  createdAt        DateTime     @default(now())

  @@index([organizationId, createdAt])
}

/// PM-requested org invite; CoCreate admin approves before Supabase invite
model ClientTeamInviteRequest {
  id                       String                        @id @default(cuid())
  organizationId           String
  organization             Organization                  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email                    String
  requestedClientOrgRole     ClientOrgRole
  canAccessSocialListening Boolean                       @default(false)
  status                   ClientTeamInviteRequestStatus @default(PENDING)
  requestedByUserId        String
  requestedBy              User                          @relation("TeamInviteRequestedBy", fields: [requestedByUserId], references: [id])
  reviewedByUserId         String?
  reviewedBy               User?                         @relation("TeamInviteReviewedBy", fields: [reviewedByUserId], references: [id])
  reviewedAt               DateTime?
  rejectionReason          String?                       @db.Text
  resultingUserId          String?
  resultingUser            User?                         @relation("TeamInviteResultingUser", fields: [resultingUserId], references: [id])
  createdAt                DateTime                      @default(now())
  updatedAt                DateTime                      @updatedAt

  @@index([organizationId, status])
  @@index([requestedByUserId])
}

// ─── Client project workspace ───────────────────────────────────────────────

enum ClientProjectStatus {
  SUBMITTED
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ClientProjectPhase {
  DISCOVERY
  IN_PROGRESS
  CLIENT_REVIEW
  READY_FOR_DELIVERY
  DELIVERED
}

enum ProjectRequestType {
  ONBOARDING
  PROGRESS
  CANCELLATION
  /// CoCreate team-only review (not visible in client portal)
  INTERNAL
}

enum ProjectMessageKind {
  CHAT
  SYSTEM
}

enum ProjectFileReactionKind {
  LOVE_THIS
  SHIP_IT
  GREAT_DIRECTION
  ANOTHER_VERSION
  NEEDS_A_TWEAK
}

enum CancellationOutcome {
  APPROVED_NO_FEE
  APPROVED_WITH_FEE
  DENIED
}

enum ProjectRequestStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  REJECTED
  CANCELLED
}

enum PortalNotificationType {
  PROJECT_SUBMITTED
  PROJECT_APPROVED
  CHANGE_REQUEST
  ADMIN_REVIEW
  PHASE_APPROVAL
  REQUEST_RESOLVED
  REQUEST_MESSAGE
  FILE_APPROVED
  FILE_CHANGES_REQUESTED
  CANCELLATION_REQUESTED
  CANCELLATION_RESOLVED
  TEAM_INVITE_REQUEST
  ORGANIZATION_MEMBERSHIP_ADDED
  ORG_INBOX_MESSAGE
}

enum ProjectMessageAuthorRole {
  ADMIN
  COLLABORATOR
  CLIENT
}

enum ProjectAttachmentVisibility {
  CLIENT
  INTERNAL
}

/// Client-initiated engagement; agency approves SUBMITTED → ACTIVE
model ClientProject {
  id               String              @id @default(cuid())
  organizationId   String
  organization     Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  title            String
  description      String              @db.Text
  status           ClientProjectStatus @default(SUBMITTED)
  phase            ClientProjectPhase  @default(DISCOVERY)
  createdByUserId  String
  createdBy        User                @relation("ProjectCreatedBy", fields: [createdByUserId], references: [id])
  /// Org Admin who owns this project (assigns Contributors/Viewers)
  ownerUserId      String
  owner            User                @relation("ProjectOwnedBy", fields: [ownerUserId], references: [id])
  approvedByUserId  String?
  approvedBy        User?               @relation("ProjectApprovedBy", fields: [approvedByUserId], references: [id])
  approvedAt        DateTime?
  completedByUserId String?
  completedBy       User?               @relation("ProjectCompletedBy", fields: [completedByUserId], references: [id])
  completedAt       DateTime?
  coverStoragePath  String?
  createdAt         DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  requests          ProjectRequest[]
  attachments       ProjectAttachment[]
  activities        ProjectActivity[]
  notifications     PortalNotification[]
  members           ClientProjectMember[]
  agencyMembers     AgencyProjectMember[]

  deletedAt DateTime?

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([createdByUserId])
  @@index([ownerUserId])
  @@index([deletedAt])
}

/// Per-project assignment for Contributors and Viewers (Admins do not need rows)
model ClientProjectMember {
  id              String        @id @default(cuid())
  projectId       String
  project         ClientProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId          String
  user            User          @relation("ProjectMembership", fields: [userId], references: [id], onDelete: Cascade)
  grantedByUserId String
  grantedBy       User          @relation("ProjectMembershipGrantedBy", fields: [grantedByUserId], references: [id])
  createdAt       DateTime      @default(now())

  @@unique([projectId, userId])
  @@index([userId])
  @@index([projectId])
}

/// Per-project access for agency collaborators (freelancers)
model AgencyProjectMember {
  id              String        @id @default(cuid())
  projectId       String
  project         ClientProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId          String
  user            User          @relation("AgencyProjectMembership", fields: [userId], references: [id], onDelete: Cascade)
  grantedByUserId String
  grantedBy       User          @relation("AgencyProjectMembershipGrantedBy", fields: [grantedByUserId], references: [id])
  createdAt       DateTime      @default(now())

  @@unique([projectId, userId])
  @@index([userId])
  @@index([projectId])
}

/// Durable conversation thread per project (onboarding, progress, cancellation)
model ProjectRequest {
  id                  String                @id @default(cuid())
  projectId           String
  project             ClientProject         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type                ProjectRequestType
  status              ProjectRequestStatus  @default(OPEN)
  title               String
  description         String                @db.Text
  targetPhase         ClientProjectPhase?
  createdByUserId     String
  createdBy           User                  @relation("RequestCreatedBy", fields: [createdByUserId], references: [id])
  resolvedByUserId    String?
  resolvedBy          User?                 @relation("RequestResolvedBy", fields: [resolvedByUserId], references: [id])
  resolvedAt          DateTime?
  cancellationOutcome CancellationOutcome?
  cancellationFeeAmount Decimal?            @db.Decimal(12, 2)
  cancellationFeeNotes  String?             @db.Text
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  attachments         ProjectAttachment[]
  notifications       PortalNotification[]
  messages            ProjectRequestMessage[]

  @@unique([projectId, type])
  @@index([projectId])
  @@index([projectId, status])
  @@index([createdByUserId])
}

/// Threaded messages on a project request (admin ↔ client)
model ProjectRequestMessage {
  id             String                   @id @default(cuid())
  requestId      String
  request        ProjectRequest           @relation(fields: [requestId], references: [id], onDelete: Cascade)
  authorUserId   String
  author         User                     @relation("RequestMessageAuthor", fields: [authorUserId], references: [id])
  authorRole     ProjectMessageAuthorRole
  body           String                   @db.Text
  messageKind    ProjectMessageKind       @default(CHAT)
  createdAt      DateTime                 @default(now())
  attachmentLinks ProjectRequestMessageAttachment[]

  @@index([requestId, createdAt])
}

/// Links project library files to specific thread messages (reusable across messages)
model ProjectRequestMessageAttachment {
  id           String                @id @default(cuid())
  messageId    String
  message      ProjectRequestMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  attachmentId String
  attachment   ProjectAttachment     @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  createdAt    DateTime              @default(now())

  @@unique([messageId, attachmentId])
  @@index([messageId])
  @@index([attachmentId])
}

/// Files stored in Supabase Storage (private bucket)
model ProjectAttachment {
  id               String          @id @default(cuid())
  projectId        String
  project          ClientProject   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requestId        String?
  request          ProjectRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)
  storagePath      String
  fileName         String
  mimeType         String
  sizeBytes        Int
  visibility       ProjectAttachmentVisibility @default(CLIENT)
  /// Admin marked this file for client sign-off when sharing in Project updates
  reviewRequested  Boolean         @default(false)
  approvedAt       DateTime?
  approvedByUserId String?
  approvedBy       User?           @relation("AttachmentApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  changesRequestedAt DateTime?
  uploadedByUserId String
  uploadedBy       User            @relation("AttachmentUploadedBy", fields: [uploadedByUserId], references: [id])
  createdAt        DateTime        @default(now())
  messageLinks     ProjectRequestMessageAttachment[]
  reactions        ProjectFileReaction[]

  @@index([projectId])
  @@index([requestId])
  @@index([projectId, visibility])
  @@index([projectId, reviewRequested])
  @@index([projectId, approvedAt])
}

/// Per-user reaction on a project file (drives Top Picks + tag filters)
model ProjectFileReaction {
  id           String                 @id @default(cuid())
  attachmentId String
  attachment   ProjectAttachment      @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  userId       String
  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind         ProjectFileReactionKind
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@unique([attachmentId, userId])
  @@index([attachmentId, kind])
  @@index([userId])
}

/// Append-only audit log per project
model ProjectActivity {
  id           String        @id @default(cuid())
  projectId    String
  project      ClientProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  action       String
  actorUserId  String
  actor        User          @relation("ActivityActor", fields: [actorUserId], references: [id])
  metadata     Json?
  createdAt    DateTime      @default(now())

  @@index([projectId, createdAt])
  @@index([action, createdAt])
  @@index([projectId, action, createdAt])
}

/// In-portal notification for a specific user
model PortalNotification {
  id             String                 @id @default(cuid())
  userId         String
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type           PortalNotificationType
  title          String
  body           String                 @db.Text
  href           String?
  readAt         DateTime?
  projectId      String?
  project        ClientProject?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  requestId      String?
  request        ProjectRequest?        @relation(fields: [requestId], references: [id], onDelete: SetNull)
  createdAt      DateTime               @default(now())

  @@index([userId, readAt])
  @@index([organizationId])
  @@index([projectId])
}

enum MessageEmailDigestChannel {
  PROJECT_REQUEST
  ORG_INBOX
}

enum MessageEmailDigestAudience {
  CLIENT
  ADMIN
}

/// Pending (or recently sent) chat email digest — one row per recipient × thread while coalescing
model MessageEmailDigest {
  id               String                     @id @default(cuid())
  recipientUserId  String
  recipient        User                       @relation(fields: [recipientUserId], references: [id], onDelete: Cascade)
  audience         MessageEmailDigestAudience
  channel          MessageEmailDigestChannel
  /// project requestId or org inbox conversationId
  threadKey        String
  organizationId   String
  organization     Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  projectId        String?
  projectTitle     String?
  /// UI label: "Project updates", "Onboarding", "Get Help"
  surfaceLabel     String
  deepLinkUrl      String
  messageCount     Int                        @default(1)
  lastPreview      String                     @db.Text
  lastAuthorLabel  String?
  scheduledSendAt  DateTime
  sentAt           DateTime?
  cancelledAt      DateTime?
  createdAt        DateTime                   @default(now())
  updatedAt        DateTime                   @updatedAt

  @@index([scheduledSendAt, sentAt, cancelledAt])
  @@index([recipientUserId, channel, threadKey])
  @@index([organizationId])
}

/// Daily (or on-demand) aggregated social listening chart payload per organization
model SocialListeningSnapshot {
  id               String       @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  /// UTC calendar date bucket for this snapshot
  snapshotDate     DateTime     @db.Date
  periodStart      DateTime
  periodEnd        DateTime
  source           String
  brand24ProjectId String?
  payload          Json
  createdAt        DateTime     @default(now())

  @@unique([organizationId, snapshotDate])
  @@index([organizationId, snapshotDate])
}

// ─── Social Listening subscriptions & setups ────────────────────────────────

enum SocialListeningPlan {
  PULSE
  GROWTH
  SCALE
}

enum SocialListeningSubscriptionStatus {
  PENDING_PAYMENT
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
}

enum SocialListeningBillingSource {
  FYGARO
  ADMIN_COMP
  ADMIN_MANUAL
}

enum SocialListeningSubscriptionCancelledBy {
  CLIENT
  ADMIN
  SYSTEM
}

enum SocialListeningSetupStatus {
  ACTIVE
  ARCHIVED
}

enum SocialListeningSetupActor {
  CLIENT
  ADMIN
}

enum SocialListeningPaymentEventType {
  INITIAL
  RENEWAL
  MANUAL_RENEWAL
  UPDATE_PAYMENT
}

enum SocialListeningBillingEmailType {
  SUBSCRIPTION_ACTIVATED
  AUTO_RENEW_UPCOMING
  MANUAL_RENEW_REMINDER
  ENABLE_AUTO_RENEW_NUDGE
  AUTO_RENEW_SUCCESS
  AUTO_RENEW_FAILED
  SUBSCRIPTION_EXPIRED
  SUBSCRIPTION_CANCELLED
}

/// One subscription record per client organization
model SocialListeningSubscription {
  id                     String                               @id @default(cuid())
  organizationId         String                               @unique
  organization           Organization                         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan                   SocialListeningPlan
  status                 SocialListeningSubscriptionStatus    @default(PENDING_PAYMENT)
  startedAt              DateTime?
  currentPeriodEnd       DateTime?
  autoRenewEnabled       Boolean                              @default(true)
  cancelAtPeriodEnd      Boolean                              @default(false)
  cancelledAt            DateTime?
  cancelledBy            SocialListeningSubscriptionCancelledBy?
  cancelReason           String?                              @db.Text
  billingSource          SocialListeningBillingSource         @default(FYGARO)
  fygaroCustomReference  String                               @unique
  paymentMethodLast4     String?
  paymentMethodBrand     String?
  paymentMethodExpMonth  Int?
  paymentMethodExpYear   Int?
  fygaroCustomerRef      String?
  createdByUserId        String?
  createdBy              User?                                @relation("SlSubscriptionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt              DateTime                             @default(now())
  updatedAt              DateTime                             @updatedAt
  paymentEvents          SocialListeningPaymentEvent[]
  billingEmailLogs       SocialListeningBillingEmailLog[]

  @@index([status])
  @@index([currentPeriodEnd])
  @@index([status, currentPeriodEnd])
}

model SocialListeningPaymentEvent {
  id                  String                          @id @default(cuid())
  subscriptionId      String
  subscription        SocialListeningSubscription     @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  eventType           SocialListeningPaymentEventType
  fygaroTransactionId String                          @unique
  amount              String
  currency            String
  rawPayload          Json
  processedAt         DateTime                        @default(now())

  @@index([subscriptionId, processedAt])
}

model SocialListeningBillingEmailLog {
  id             String                          @id @default(cuid())
  subscriptionId String
  subscription   SocialListeningSubscription     @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  emailType      SocialListeningBillingEmailType
  periodEnd      DateTime
  recipientEmail String
  resendMessageId String?
  sentAt         DateTime                        @default(now())

  @@unique([subscriptionId, emailType, periodEnd])
  @@index([subscriptionId, sentAt])
}

model SocialListeningSetup {
  id                String                     @id @default(cuid())
  organizationId    String
  organization      Organization               @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  status            SocialListeningSetupStatus @default(ACTIVE)
  keywords          Json
  platforms         Json
  startDate         DateTime                   @db.Date
  endDate           DateTime                   @db.Date
  brand24ProjectId  String?
  snapshotsCaptured Int                        @default(0)
  createdByActor    SocialListeningSetupActor  @map("createdBy")
  createdByUserId   String?
  createdByUser     User?                      @relation("SlSetupCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt         DateTime                   @default(now())

  @@index([organizationId, status])
  @@index([organizationId, createdAt])
}

// ─── Org-wide client ↔ CoCreate messaging ───────────────────────────────────

enum OrgInboxVisibility {
  ORG_WIDE
  RESTRICTED
}

enum OrgInboxAuthorRole {
  CLIENT
  ADMIN
}

model OrgInboxConversation {
  id              String              @id @default(cuid())
  organizationId  String
  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdByUserId String
  createdBy       User                @relation("OrgInboxCreatedBy", fields: [createdByUserId], references: [id])
  visibility      OrgInboxVisibility
  subject         String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  participants    OrgInboxParticipant[]
  messages        OrgInboxMessage[]
  readCursors     OrgInboxReadCursor[]
  attachments     OrgInboxAttachment[]

  @@index([organizationId, updatedAt])
}

model OrgInboxParticipant {
  conversationId String
  conversation   OrgInboxConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User                 @relation("OrgInboxParticipant", fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId])
}

model OrgInboxMessage {
  id             String               @id @default(cuid())
  conversationId String
  conversation   OrgInboxConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  authorUserId   String
  author         User                 @relation("OrgInboxMessageAuthor", fields: [authorUserId], references: [id])
  authorRole     OrgInboxAuthorRole
  body           String               @db.Text
  createdAt      DateTime             @default(now())
  attachmentLinks OrgInboxMessageAttachment[]

  @@index([conversationId, createdAt])
}

model OrgInboxAttachment {
  id               String   @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversationId   String
  conversation     OrgInboxConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  storagePath      String
  fileName         String
  mimeType         String
  sizeBytes        Int
  uploadedByUserId String
  uploadedBy       User     @relation("OrgInboxAttachmentUploader", fields: [uploadedByUserId], references: [id])
  createdAt        DateTime @default(now())
  messageLinks     OrgInboxMessageAttachment[]

  @@index([conversationId])
  @@index([organizationId])
}

model OrgInboxMessageAttachment {
  id           String             @id @default(cuid())
  messageId    String
  message      OrgInboxMessage    @relation(fields: [messageId], references: [id], onDelete: Cascade)
  attachmentId String
  attachment   OrgInboxAttachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  createdAt    DateTime           @default(now())

  @@unique([messageId, attachmentId])
  @@index([messageId])
  @@index([attachmentId])
}

model OrgInboxReadCursor {
  conversationId String
  conversation   OrgInboxConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User                 @relation("OrgInboxReadCursor", fields: [userId], references: [id], onDelete: Cascade)
  lastReadAt     DateTime             @default(now())

  @@id([conversationId, userId])
}

/// Portal account — agency admins (ADMIN) or client contacts (CLIENT)
model User {
  id             String        @id @default(cuid())
  email          String        @unique
  /// Supabase Auth user id (linked after invite or first sign-in)
  supabaseAuthId String?       @unique
  /// @deprecated Prefer ClientOrganizationMembership; kept for migration dual-read
  organizationId String?
  organization            Organization?          @relation("UserLegacyOrganization", fields: [organizationId], references: [id], onDelete: Cascade)
  /// Last org the client portal session used (multi-membership)
  lastActiveOrganizationId String?
  lastActiveOrganization   Organization?         @relation("UserLastActiveOrganization", fields: [lastActiveOrganizationId], references: [id], onDelete: SetNull)
  role                    UserRole               @default(CLIENT)
  status                  UserStatus             @default(INVITED)
  /// @deprecated Prefer membership.clientOrgRole
  clientOrgRole           ClientOrgRole?
  /// @deprecated Prefer membership.canAccessSocialListening
  canAccessSocialListening Boolean               @default(false)
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  deletedAt               DateTime?
  organizationMemberships ClientOrganizationMembership[]
  projectsCreated         ClientProject[]        @relation("ProjectCreatedBy")
  projectsOwned           ClientProject[]        @relation("ProjectOwnedBy")
  projectsApproved        ClientProject[]        @relation("ProjectApprovedBy")
  projectsCompleted       ClientProject[]        @relation("ProjectCompletedBy")
  requestsCreated         ProjectRequest[]       @relation("RequestCreatedBy")
  requestsResolved        ProjectRequest[]       @relation("RequestResolvedBy")
  attachmentsUploaded     ProjectAttachment[]    @relation("AttachmentUploadedBy")
  attachmentsApproved     ProjectAttachment[]    @relation("AttachmentApprovedBy")
  brandAssetsUploaded     OrganizationBrandAsset[] @relation("BrandAssetUploadedBy")
  projectActivities       ProjectActivity[]      @relation("ActivityActor")
  portalNotifications     PortalNotification[]
  requestMessages         ProjectRequestMessage[] @relation("RequestMessageAuthor")
  fileReactions           ProjectFileReaction[]
  projectMemberships      ClientProjectMember[]   @relation("ProjectMembership")
  projectMembershipsGranted ClientProjectMember[] @relation("ProjectMembershipGrantedBy")
  agencyProjectMemberships AgencyProjectMember[]  @relation("AgencyProjectMembership")
  agencyProjectMembershipsGranted AgencyProjectMember[] @relation("AgencyProjectMembershipGrantedBy")
  teamInvitesRequested      ClientTeamInviteRequest[] @relation("TeamInviteRequestedBy")
  teamInvitesReviewed       ClientTeamInviteRequest[] @relation("TeamInviteReviewedBy")
  teamInvitesResulting      ClientTeamInviteRequest[] @relation("TeamInviteResultingUser")
  profile                 UserProfile?
  preferences             UserPreferences?
  orgInboxConversationsCreated OrgInboxConversation[] @relation("OrgInboxCreatedBy")
  orgInboxParticipations    OrgInboxParticipant[]     @relation("OrgInboxParticipant")
  orgInboxMessages          OrgInboxMessage[]         @relation("OrgInboxMessageAuthor")
  orgInboxAttachmentsUploaded OrgInboxAttachment[]    @relation("OrgInboxAttachmentUploader")
  orgInboxReadCursors       OrgInboxReadCursor[]      @relation("OrgInboxReadCursor")
  socialListeningSubscriptionsCreated SocialListeningSubscription[] @relation("SlSubscriptionCreatedBy")
  socialListeningSetupsCreated        SocialListeningSetup[]        @relation("SlSetupCreatedBy")
  messageEmailDigests       MessageEmailDigest[]
  /// Last portal activity (heartbeat) — used to suppress chat email digests while active
  lastSeenAt                DateTime?

  @@index([organizationId])
  @@index([organizationId, clientOrgRole])
  @@index([lastActiveOrganizationId])
  @@index([email])
  @@index([status])
  @@index([deletedAt])
  @@index([lastSeenAt])
}

/// Per-org membership for CLIENT users (same email/login can belong to many orgs)
model ClientOrganizationMembership {
  id                       String        @id @default(cuid())
  userId                   String
  user                     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organizationId           String
  organization             Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  clientOrgRole            ClientOrgRole
  status                   UserStatus    @default(INVITED)
  canAccessSocialListening Boolean       @default(false)
  /// Per-member Get Help (org inbox) access; Admins always have access in app logic
  canAccessGetHelp         Boolean       @default(true)
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([organizationId, clientOrgRole])
  @@index([organizationId, status])
  @@index([userId, status])
}

/// Agency-wide job title options (managed by super admins)
model AgencyProfileOption {
  id        String   @id @default(cuid())
  label     String   @unique
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profileJobTitles UserProfileJobTitle[]

  @@index([isActive, sortOrder])
}

/// Account-level UI preferences (synced across devices)
model UserPreferences {
  userId    String   @id
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// light | dark | system
  theme     String   @default("system")
  /// Future preference keys without schema churn
  extras    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Cached AI-generated summary for a messaging thread
model ThreadSummary {
  id            String   @id @default(cuid())
  sourceType    String
  sourceId      String
  messageCount  Int
  lastMessageAt DateTime
  content       Json
  model         String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([sourceType, sourceId])
  @@index([sourceType, sourceId])
}

/// Display identity for portal users (admins set name/title for project attribution)
model UserProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName       String?
  /// Denormalized job title labels (comma-separated, synced on save)
  jobTitle          String?
  avatarStoragePath String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  jobTitles UserProfileJobTitle[]
}

model UserProfileJobTitle {
  id        String              @id @default(cuid())
  profileId String
  profile   UserProfile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  optionId  String
  option    AgencyProfileOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  sortOrder Int                 @default(0)

  @@unique([profileId, optionId])
  @@index([profileId, sortOrder])
}

// ─── Contact chat (marketing site) ──────────────────────────────────────────

/// Contact-page chat threads (Vercel AI SDK on web; Nest can persist via API later)
model ContactConversation {
  id        String           @id @default(cuid())
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  messages  ContactMessage[]
}

model ContactMessage {
  id             String              @id @default(cuid())
  conversationId String
  conversation   ContactConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String              @db.Text
  createdAt      DateTime            @default(now())

  @@index([conversationId])
}

// ─── Marketing newsletter (double opt-in) ───────────────────────────────────

enum NewsletterStatus {
  PENDING
  CONFIRMED
  UNSUBSCRIBED
}

model NewsletterSubscriber {
  id                    String           @id @default(cuid())
  email                 String           @unique
  status                NewsletterStatus @default(PENDING)
  confirmTokenHash      String?
  confirmTokenExpiresAt DateTime?
  resendContactId       String?
  confirmedAt           DateTime?
  source                String           @default("footer")
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  @@index([status])
  @@index([confirmTokenHash])
}
