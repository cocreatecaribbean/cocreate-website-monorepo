{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "declaration": true,
    "outDir": "./dist/core",
    "rootDir": "./src/core",
    "paths": {
      "@cocreate/api-contracts/v1/*": ["../api-contracts/dist/v1/*"]
    },
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["src/core/**/*.ts"],
  "exclude": ["src/core/**/*.spec.ts", "node_modules", "dist"]
}
