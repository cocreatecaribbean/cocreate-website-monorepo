{
  "name": "@cocreate/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "predev": "sh -c 'test -f ../../packages/api-contracts/dist/index.js || pnpm --filter @cocreate/api-contracts build; test -f ../../packages/message-summary/dist/enrich-summary.js || pnpm --filter @cocreate/message-summary build; test -f ../../packages/ai-core/dist/models.js || pnpm --filter @cocreate/ai-core build'",
    "dev": "concurrently -n contracts,summary,api -c blue,magenta,green \"pnpm --filter @cocreate/api-contracts dev\" \"pnpm --filter @cocreate/message-summary dev\" \"PORT=3001 nest start --watch\"",
    "start": "nest start",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "type-check": "tsc --noEmit",
    "test": "jest"
  },
  "dependencies": {
    "@cocreate/api-contracts": "workspace:*",
    "@cocreate/ai-core": "workspace:*",
    "@cocreate/database": "workspace:*",
    "@cocreate/message-summary": "workspace:*",
    "@cocreate/social-listening-plans": "workspace:*",
    "@cocreate/social-listening-reports": "workspace:*",
    "ai": "catalog:ai",
    "@ai-sdk/openai": "catalog:ai",
    "zod": "catalog:web",
    "@nestjs/common": "catalog:api",
    "@nestjs/config": "catalog:api",
    "@nestjs/core": "catalog:api",
    "@nestjs/platform-express": "catalog:api",
    "@nestjs/platform-socket.io": "11.1.23",
    "@nestjs/schedule": "catalog:api",
    "@nestjs/websockets": "11.1.23",
    "@nestjs/swagger": "^11.2.0",
    "@prisma/adapter-pg": "catalog:api",
    "@supabase/supabase-js": "^2.49.8",
    "dotenv": "^16.4.7",
    "pg": "catalog:api",
    "resend": "^6.12.3",
    "reflect-metadata": "catalog:api",
    "rxjs": "catalog:api",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "catalog:api",
    "@nestjs/schematics": "catalog:api",
    "@nestjs/testing": "^11.1.23",
    "@types/jest": "^29.5.14",
    "@types/supertest": "^6.0.3",
    "jest": "catalog:tooling",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.4",
    "@types/express": "^5.0.6",
    "@types/node": "catalog:tooling",
    "@types/pg": "catalog:api",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.11.0",
    "concurrently": "catalog:web",
    "typescript": "catalog:tooling"
  }
}
