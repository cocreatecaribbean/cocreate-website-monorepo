PORT=3001
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3002,http://localhost:3003
CLIENT_PORTAL_URL=http://localhost:3003
ADMIN_CENTER_URL=http://localhost:3002
ADMIN_API_KEY=dev-admin-key-change-me

# Runtime — Supabase pooling URL (:6543)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cocreate?schema=public"
DATABASE_POOL_MAX=10

# Supabase Auth
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Development only — print/open sign-in links instead of sending email (avoids Supabase rate limits)
AUTH_DEV_LINKS=true

# Resend — when AUTH_DEV_LINKS=false and RESEND_API_KEY is set, auth emails use Resend (not Supabase SMTP)
RESEND_API_KEY=re_xxxxxxxx
AUTH_EMAIL_FROM=no-reply@mail.cocreatecaribbean.com
AUTH_EMAIL_FROM_NAME=CoCreate Caribbean
# AUTH_USE_RESEND_API=false  # force Supabase SMTP instead

# Newsletter (footer double opt-in on marketing site)
WEB_URL=http://localhost:3000
# Resend Dashboard → Segments → copy segment ID
RESEND_SEGMENT_ID=your-segment-id-from-resend-dashboard
# Deprecated: legacy Audiences API only (use RESEND_SEGMENT_ID instead)
# RESEND_AUDIENCE_ID=your-legacy-audience-id
# NEWSLETTER_FROM_EMAIL=no-reply@mail.cocreatecaribbean.com
# NEWSLETTER_FROM_NAME=CoCreate Caribbean

# Brand24 / BrandMentions — off by default; charts use per-org mock data
# BRAND24_API_KEY=
# BRANDMENTIONS_API_KEY=
# BRAND24_API_BASE_URL=https://api.brandmentions.com/command.php
# BRAND24_USE_LIVE_API=true
