# Reference only — secrets live in Doppler (see docs/doppler.md).

PORT=3001
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3002,http://localhost:3003
CLIENT_PORTAL_URL=http://localhost:3003
ADMIN_CENTER_URL=http://localhost:3002
ADMIN_API_KEY=dev-admin-key-change-me

# Runtime — Supabase pooling URL (:6543)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cocreate?schema=public"
DATABASE_POOL_MAX=10

# Supabase Auth
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Development only — print/open sign-in links instead of sending email (avoids Supabase rate limits)
AUTH_DEV_LINKS=true

# Resend — when AUTH_DEV_LINKS=false and RESEND_API_KEY is set, auth emails use Resend (not Supabase SMTP)
RESEND_API_KEY=re_xxxxxxxx
AUTH_EMAIL_FROM=no-reply@mail.cocreatecaribbean.com
AUTH_EMAIL_FROM_NAME=CoCreate Caribbean
# AUTH_USE_RESEND_API=false  # force Supabase SMTP instead

# Newsletter (footer double opt-in on marketing site)
WEB_URL=http://localhost:3000
# Resend Dashboard → Segments → copy segment ID
RESEND_SEGMENT_ID=your-segment-id-from-resend-dashboard
# Deprecated: legacy Audiences API only (use RESEND_SEGMENT_ID instead)
# RESEND_AUDIENCE_ID=your-legacy-audience-id
NEWSLETTER_FROM_EMAIL=signup@mail.cocreatecaribbean.com
NEWSLETTER_FROM_NAME=CoCreate Caribbean

# Client project workspace notifications (checkpoints, messages, onboarding, etc.)
# Do not use AUTH_EMAIL_FROM or NEWSLETTER_FROM_EMAIL for these.
PROJECT_UPDATES_FROM_EMAIL=updates@mail.cocreatecaribbean.com
PROJECT_UPDATES_FROM_NAME=CoCreate Caribbean

# Brand24 / BrandMentions — off by default; charts use per-org mock data
# Set BRAND24_USE_LIVE_API=true only when credentials are configured.
# BRAND24_API_KEY=
# BRANDMENTIONS_API_KEY=
# BRAND24_API_BASE_URL=https://api.brandmentions.com/command.php
# BRAND24_USE_LIVE_API=true

# Social listening — daily snapshots + historical compare in client portal
SOCIAL_LISTENING_SNAPSHOT_ENABLED=true
SOCIAL_LISTENING_SNAPSHOT_MAX_AGE_HOURS=24
SOCIAL_LISTENING_SNAPSHOT_RETENTION_DAYS=548
# Local demo: auto-seed today + ~90 days ago (org-scoped mock) when snapshots are missing
# Production: set SOCIAL_LISTENING_DEMO_SNAPSHOTS=false (mock fallback still works per-org without Brand24)
SOCIAL_LISTENING_DEMO_SNAPSHOTS=true
SOCIAL_LISTENING_DEMO_SNAPSHOT_DAYS_AGO=90

# Fygaro billing (Social Listening subscriptions)
# Webhook URL (Railway): https://<api-host>/webhooks/fygaro  (version-neutral, raw body required)
# FYGARO_SECRET=
# FYGARO_KEY_ID=
# FYGARO_PAYMENT_BUTTON_URL=
# FYGARO_WEBHOOK_SECRETS=
# Failed renewal webhooks use customReference event types renewal_failed / payment_failed (grace period: 3 days)

# Social Listening billing emails (renewal reminders, payment confirmations)
BILLING_FROM_EMAIL=billingupdates@mail.cocreatecaribbean.com
BILLING_FROM_NAME=CoCreate Billing

# AI thread summaries (client portal + admin center project threads and org inbox)
OPENAI_API_KEY=
# Or Vercel AI Gateway when not deployed on Vercel
AI_GATEWAY_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_SUMMARY_MODEL=gpt-4o
