# Copy to apps/web/.env.local and fill in values (never commit .env.local)

# Sanity (public — exposed to the browser)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-03-01

# Resend (server only — do NOT prefix with NEXT_PUBLIC_)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Verified sender/domain in Resend (e.g. onboarding@resend.dev for testing, or hello@yourdomain.com)
RESEND_FROM_EMAIL=onboarding@resend.dev
