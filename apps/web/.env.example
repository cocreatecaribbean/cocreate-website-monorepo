# Reference only — secrets live in Doppler (see docs/doppler.md).
# Copy to apps/web/.env.local is not required; use `pnpm dev` after `doppler setup`.

# Sanity (public — exposed to the browser)
# When unset or empty, work and originals pages stay empty until Sanity is configured.
NEXT_PUBLIC_SANITY_PROJECT_ID=5ix7h4ht
NEXT_PUBLIC_SANITY_DATASET=dev
NEXT_PUBLIC_SANITY_API_VERSION=2026-03-01
NEXT_PUBLIC_SANITY_STUDIO_URL=http://localhost:3333

# Server only — Presentation preview + live content (do NOT prefix with NEXT_PUBLIC_)
SANITY_API_TOKEN=
SANITY_REVALIDATE_SECRET=
# Must match Studio dataset when validating preview secrets
SANITY_STUDIO_DATASET=dev

# YouTube Data API (Studio playlist sync for podcast originals — also SANITY_STUDIO_YOUTUBE_API_KEY)
# YOUTUBE_API_KEY=

# Resend (server only — do NOT prefix with NEXT_PUBLIC_)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Verified sender/domain in Resend (e.g. onboarding@resend.dev for testing, or hello@yourdomain.com)
RESEND_FROM_EMAIL=onboarding@resend.dev

# NestJS backend (newsletter subscribe, client portal login BFF, etc.)
NEXT_PUBLIC_API_URL=http://localhost:3001
API_URL=http://localhost:3001

# Contact form (server only)
# Canonical production inbox for website contact messages
CONTACT_TO_EMAIL=requests@cocreatecaribbean.com

# Cloudflare Turnstile (contact form anti-bot)
# Public site key (safe for browser). Local/test always-pass: 1x00000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
# Server secret. Local/test always-pass: 1x0000000000000000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Upstash Redis (distributed contact rate limiting — server only)
# Optional locally: omit both to skip rate limiting. Recommended for staging/prod.
# Use the REST URL + token from the Upstash console (not the redis:// connection string).
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxxxx

# Contact page AI chat (Vercel AI SDK — /api/chat)
OPENAI_API_KEY=
# Or Vercel AI Gateway when not deployed on Vercel
AI_GATEWAY_API_KEY=
OPENAI_MODEL=gpt-4o-mini
